{
  "log_dir": "logs",
  "configured_handlers": [
  	"com.chatgpt",
	"com.youtube",
  	"org.mon-net",
  	"com.google",
  	"com.duckduckgo",
	"org.mozilla.telemetry",
	"local",
  	"fallback_handler"
  ],
  "field_rules": [
    {
      "pattern": "email",
      "log_name": "email",
      "value_regex": "(^.).*(@.*$)",
      "mode": "obfuscate"
    },
    {
      "pattern": "phone",
      "log_name": "phone",
      "value_regex": "\\d",
      "mode": "obfuscate"
    },
    {
      "pattern": "(pass|pwd|token|secret|auth)",
      "log_name": null,
      "value_regex": null,
      "mode": "never"
    },
    {
      "pattern": "(username|name|login)",
      "log_name": "login",
      "value_regex": null,
      "mode": "log"
    },
    {
      "pattern": ".*",
      "log_name": null,
      "value_regex": null,
      "mode": "log"
    }
  ]
}
